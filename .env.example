# NextAuth Configuration (localhost)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-long-random-string

# Database (Single source of truth: Supabase Postgres)
# Keep both values from your Supabase project connection strings.
POSTGRES_PRISMA_URL="postgres://<user>:<password>@<pooler-host>:6543/postgres?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://<user>:<password>@<direct-host>:5432/postgres?sslmode=require"

# Optional Supabase client vars (only needed if frontend uses Supabase SDK directly)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# GitHub OAuth (optional)
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# Email (optional)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@yourdomain.com
