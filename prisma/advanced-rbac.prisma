// Prisma schema additions for advanced RBAC

model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) // System roles can't be deleted
  permissions Json     // Permission matrix for this role
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  users User[]

  @@index([name])
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique // e.g., "MUM-WEST"
  description String?
  location    String?
  parentId    String?
  parent      Team?    @relation("TeamHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Team[]   @relation("TeamHierarchy")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  members     User[]
  shipments   Shipment[]

  @@index([name])
  @@index([code])
  @@index([location])
}

model PermissionRequest {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedRole String
  currentRole   String
  reason        String
  status        PermissionRequestStatus @default(PENDING)
  reviewedBy    String?
  reviewer      User?             @relation("PermissionRequestReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt    DateTime?
  reviewNotes   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId])
  @@index([status])
  @@index([reviewedBy])
}

model TemporaryAccess {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grantedBy    String
  granter      User     @relation("TemporaryAccessGranter", fields: [grantedBy], references: [id], onDelete: Cascade)
  role         String
  permissions  Json?    // Additional temporary permissions
  reason       String
  expiresAt    DateTime
  isRevoked    Boolean  @default(false)
  revokedAt    DateTime?
  revokedBy    String?
  revoker      User?    @relation("TemporaryAccessRevoker", fields: [revokedBy], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([isRevoked])
}

model Delegation {
  id           String       @id @default(cuid())
  fromUserId   String
  fromUser     User         @relation("DelegationFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId     String
  toUser       User         @relation("DelegationTo", fields: [toUserId], references: [id], onDelete: Cascade)
  permissions  Json         // Array of permission keys delegated
  reason       String
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([fromUserId])
  @@index([toUserId])
  @@index([isActive])
  @@index([endDate])
}

model ApprovalThreshold {
  id              String   @id @default(cuid())
  entityType      String   // Shipment, Complaint, etc.
  action          String   // delete, complete, approve, etc.
  requiredRole    String   // Minimum role required
  requiresMFA     Boolean  @default(false)
  approvalCount   Int      @default(1) // Number of approvals needed
  isAmountBased   Boolean  @default(false) // If true, check threshold amount
  thresholdAmount Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([entityType, action])
  @@index([entityType])
  @@index([requiredRole])
}

model MFARequirement {
  id          String   @id @default(cuid())
  action      String   @unique // e.g., "delete_shipment", "bulk_complete"
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([action])
  @@index([isActive])
}

enum PermissionRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}
