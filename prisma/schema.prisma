// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
  USER
}

enum ShipmentStatus {
  PROCESSING
  IN_TRANSIT
  DELIVERED
  PENDING
  CANCELLED
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  SOLVED
  CLOSED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RepossessionStatus {
  PENDING
  SCHEDULED
  COLLECTED
  COMPLETED
  CANCELLED
}

enum RedeploymentStatus {
  PROCESSING
  SCHEDULED
  DEPLOYED
  COMPLETED
  CANCELLED
}

// ==================== MODELS ====================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?

  verificationTokens VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  sessions           Session[]
  shipments          Shipment[]
  complaints         Complaint[]
  repossessions      Repossession[]
  redeployments      Redeployment[]
  auditLogs          AuditLog[]

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([sessionToken])
}

model Shipment {
  id              String         @id @default(cuid())
  podName         String
  shippingAddress String
  contactPerson   String
  mobileNumber    String
  peripherals     String
  orderDate       DateTime
  dispatchDate    DateTime?
  deliveryDate    DateTime?
  setupDate       DateTime?
  status          ShipmentStatus @default(PROCESSING)
  totalCost       Decimal        @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted       Boolean        @default(false)
  deletedAt       DateTime?

  auditLogs AuditLog[]

  @@index([userId])
  @@index([status])
  @@index([orderDate])
  @@index([isDeleted])
}

model Complaint {
  id          String            @id @default(cuid())
  computerId  String
  issue       String
  description String?
  status      ComplaintStatus   @default(PENDING)
  priority    ComplaintPriority @default(MEDIUM)
  resolvedAt  DateTime?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted   Boolean           @default(false)
  deletedAt   DateTime?

  auditLogs AuditLog[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([computerId])
  @@index([isDeleted])
}

model Repossession {
  id          String             @id @default(cuid())
  podName     String
  computerId  String
  reason      String
  status      RepossessionStatus @default(PENDING)
  collectedAt DateTime?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted   Boolean            @default(false)
  deletedAt   DateTime?

  auditLogs AuditLog[]

  @@index([userId])
  @@index([status])
  @@index([computerId])
  @@index([isDeleted])
}

model Redeployment {
  id          String            @id @default(cuid())
  shipmentId  String?
  destination String
  status      RedeploymentStatus @default(PROCESSING)
  deployedAt  DateTime?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted   Boolean           @default(false)
  deletedAt   DateTime?

  auditLogs AuditLog[]

  @@index([userId])
  @@index([status])
  @@index([shipmentId])
  @@index([isDeleted])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // CREATE, UPDATE, DELETE, VIEW, etc.
  entityType String  // Shipment, Complaint, etc.
  entityId  String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress String?
  userAgent String?
  changes   Json?    // Store before/after values
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}
