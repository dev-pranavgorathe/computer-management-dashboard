// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

// ==================== MODELS ====================
// Note: Using String instead of Enum for SQLite compatibility

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // ADMIN, MANAGER, VIEWER, USER
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?

  verificationTokens VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  sessions           Session[]
  shipments          Shipment[]
  complaints         Complaint[]
  repossessions      Repossession[]
  redeployments      Redeployment[]
  auditLogs          AuditLog[]

  @@index([email])
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([sessionToken])
}

model Shipment {
  id              String   @id @default(cuid())
  refId           String   @unique // "SHP-001"
  podName         String
  shippingAddress String
  contactPerson   String
  mobileNumber    String
  
  // PRD fields
  cpus            Int      @default(1)
  components      String?  // Auto-populated from cpus
  serials         String?  // Comma-separated serial numbers
  trackingId      String?  // Vendor tracking reference
  qcReport        String?  // QC report filename (from vendor)
  signedQc        String?  // Signed QC report filename (required for Completed)
  
  orderDate       DateTime
  dispatchDate    DateTime?
  deliveryDate    DateTime?
  // Status: PENDING | ORDER_SENT | DISPATCHED | IN_TRANSIT | DELIVERED | COMPLETED
  status          String   @default("PENDING")
  totalCost       Float    @default(0)
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted       Boolean  @default(false)
  deletedAt       DateTime?

  @@index([userId])
  @@index([status])
  @@index([orderDate])
  @@index([isDeleted])
  @@index([refId])
}

model Complaint {
  id            String   @id @default(cuid())
  refId         String   @unique // "CMP-001"
  ticket        String   @unique // "TKT-XXXX" auto-generated
  
  // PRD fields
  podName       String
  phase         String?  // Optional at creation, editable later
  deviceType    String   @default("CPU") // MONITOR | CPU | KEYBOARD | MOUSE | WEBCAM | HEADPHONES | PSU | NETWORK_ADAPTER | OTHER
  deviceSerial  String?
  issue         String   // Short issue summary
  description   String?
  contactPerson String?
  mobileNumber  String?
  reportedDate  DateTime @default(now())
  solvedDate    DateTime?
  resolution    String?
  remarks       String?
  attachments   String?  // Comma-separated filenames
  
  // Status: OPEN | IN_PROGRESS | SOLVED
  status        String   @default("OPEN")
  // Priority: LOW | MEDIUM | HIGH | CRITICAL
  priority      String   @default("MEDIUM")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted     Boolean  @default(false)
  deletedAt     DateTime?

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([deviceSerial])
  @@index([isDeleted])
  @@index([refId])
  @@index([ticket])
}

model Repossession {
  id            String   @id @default(cuid())
  refId         String   @unique // "REP-001"
  ticket        String   @unique // "TKT-XXXX" auto-generated
  
  // PRD fields
  podName       String
  shippingAddress String?
  contactPerson String?
  mobileNumber  String?
  components    String?  // Equipment to be collected
  serials       String?  // Fillable after collection
  reshippedDate DateTime?
  notes         String?
  
  // Status: PENDING | COLLECTED | IN_PROGRESS | COMPLETED
  status        String   @default("PENDING")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted     Boolean  @default(false)
  deletedAt     DateTime?

  @@index([userId])
  @@index([status])
  @@index([isDeleted])
  @@index([refId])
  @@index([ticket])
}

model Redeployment {
  id             String   @id @default(cuid())
  refId          String   @unique // "RDP-001"
  
  // PRD fields
  podName        String   // Destination POD
  shippingAddress String?
  contactPerson  String?
  mobileNumber   String?
  sourcePod      String?  // Source POD
  components     String?
  serials        String?
  complaintTicket String? // Linked complaint ticket for traceability
  trackingId     String?
  orderDate      DateTime @default(now())
  dispatchDate   DateTime?
  deliveryDate   DateTime?
  
  // Status: PENDING | ORDER_SENT | IN_TRANSIT | DELIVERED | COMPLETED
  status         String   @default("PENDING")
  notes          String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted      Boolean  @default(false)
  deletedAt      DateTime?

  @@index([userId])
  @@index([status])
  @@index([isDeleted])
  @@index([refId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String   // CREATE, UPDATE, DELETE, VIEW, STATUS_CHANGE, etc.
  entityType String   // Shipment, Complaint, Repossession, Redeployment
  entityId   String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress  String?
  userAgent  String?
  changes    String?  // JSON string for before/after values
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}
