// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("DATABASE_URL")
}

// ==================== MODELS ====================
// Note: Using String instead of Enum for SQLite compatibility

model User {
  id            String      @id @default(cuid())
  name          String
  email         String      @unique
  password      String
  emailVerified DateTime?
  image         String?
  role          String      @default("USER") // ADMIN, MANAGER, VIEWER, USER, SUPER_ADMIN
  customRoleId  String?
  customRole    CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  teamId        String?
  team          Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  isDeleted     Boolean     @default(false)
  deletedAt     DateTime?

  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  sessions            Session[]
  shipments           Shipment[]
  ownedShipments      Shipment[]           @relation("ShipmentOwner")
  complaints          Complaint[]
  repossessions       Repossession[]
  redeployments       Redeployment[]
  auditLogs           AuditLog[]
  approvalsRequested  ApprovalRequest[]    @relation("ApprovalRequester")
  approvalsReviewed   ApprovalRequest[]    @relation("ApprovalApprover")
  permissionRequests  PermissionRequest[]  @relation("PermissionRequestUser")
  reviewedRequests    PermissionRequest[]  @relation("PermissionRequestReviewer")
  temporaryAccess     TemporaryAccess[]    @relation("TemporaryAccessUser")
  grantedAccess       TemporaryAccess[]    @relation("TemporaryAccessGranter")
  revokedAccess       TemporaryAccess[]    @relation("TemporaryAccessRevoker")
  delegationsGiven    Delegation[]         @relation("DelegationFrom")
  delegationsReceived Delegation[]         @relation("DelegationTo")

  @@index([email])
  @@index([role])
  @@index([teamId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([sessionToken])
}

model Shipment {
  id              String  @id @default(cuid())
  refId           String  @unique // "SHP-001"
  podName         String
  shippingAddress String
  state           String? // State/Region (auto-filled or manual)
  pincode         String? // Pincode
  contactPerson   String
  mobileNumber    String

  // PRD fields
  cpus           Int     @default(1)
  components     String? // Auto-populated from cpus
  serials        String? // Comma-separated serial numbers
  trackingId     String? // Vendor tracking reference
  qcReport       String? // QC report filename (from vendor)
  signedQc       String? // Signed QC report filename (required for Completed)
  additionalDocs String? // Additional document filenames (comma-separated)
  purpose        String? // Purpose: NEW_POD | MANTHAN_POD | TEACH_TO_EARN | PERIPHERALS | OTHER

  orderDate    DateTime
  dispatchDate DateTime?
  deliveryDate DateTime?
  // Status: PENDING | ORDER_SENT | DISPATCHED | IN_TRANSIT | DELIVERED | COMPLETED
  status       String    @default("PENDING")
  totalCost    Float     @default(0)
  notes        String?
  mailSent     Boolean   @default(false) // Track if order mail was sent
  mailSentAt   DateTime? // When the mail was sent

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownerId        String?
  owner          User?     @relation("ShipmentOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  teamId         String?
  teamRel        Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  team           String? // Team name/code for quick reference
  location       String?
  approvalStatus String    @default("NOT_REQUIRED") // NOT_REQUIRED | PENDING | APPROVED | REJECTED
  isDeleted      Boolean   @default(false)
  deletedAt      DateTime?

  @@index([userId])
  @@index([ownerId])
  @@index([teamId])
  @@index([team])
  @@index([status])
  @@index([approvalStatus])
  @@index([orderDate])
  @@index([isDeleted])
  @@index([refId])
  @@index([state])
  @@index([pincode])
}

model Complaint {
  id     String  @id @default(cuid())
  refId  String  @unique // "CMP-001"
  ticket String? // "TKT-XXXX" - manually entered or N/A

  // PRD fields
  podName          String
  phase            String? // Optional at creation, editable later
  deviceType       String    @default("CPU") // MONITOR | CPU | KEYBOARD | MOUSE | WEBCAM | HEADPHONES | PSU | NETWORK_ADAPTER | OTHER
  deviceSerial     String?
  issue            String // Short issue summary
  description      String?
  contactPerson    String?
  mobileNumber     String?
  reportedDate     DateTime  @default(now())
  solvedDate       DateTime?
  resolution       String?
  resolutionMethod String? // Repaired | Replaced (Under Warranty) | Replaced (Out of Warranty) | Redeployment | Other
  remarks          String?
  attachments      String? // Comma-separated filenames or URLs

  // Status: OPEN | IN_PROGRESS | SOLVED
  status     String    @default("OPEN")
  // Priority: LOW | MEDIUM | HIGH | CRITICAL
  priority   String    @default("MEDIUM")
  mailSent   Boolean   @default(false) // Track if vendor mail was sent
  mailSentAt DateTime? // When the mail was sent

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([deviceSerial])
  @@index([isDeleted])
  @@index([refId])
  @@index([ticket])
  @@index([resolutionMethod])
}

model Repossession {
  id     String  @id @default(cuid())
  refId  String  @unique // "REP-001"
  ticket String? // Manually entered ticket number (optional)

  // PRD fields
  podName         String
  shippingAddress String?
  contactPerson   String?
  mobileNumber    String?
  components      String? // Equipment to be collected
  serials         String? // Fillable after collection
  reshippedDate   DateTime?
  notes           String?
  mailSent        Boolean   @default(false) // Track if mail was sent
  mailSentAt      DateTime? // When the mail was sent

  // Status: PENDING | COLLECTED | IN_PROGRESS | COMPLETED
  status String @default("PENDING")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([isDeleted])
  @@index([refId])
  @@index([ticket])
}

model Redeployment {
  id    String @id @default(cuid())
  refId String @unique // "RDP-001"

  // PRD fields
  podName         String // Destination POD
  shippingAddress String?
  contactPerson   String?
  mobileNumber    String?
  sourcePod       String? // Source POD (filled after vendor dispatch)
  components      String?
  serials         String?
  complaintTicket String? // Linked complaint ticket for traceability (optional, can be N/A)
  trackingId      String?
  orderDate       DateTime  @default(now())
  dispatchDate    DateTime?
  deliveryDate    DateTime?
  mailSent        Boolean   @default(false) // Track if mail was sent
  mailSentAt      DateTime? // When the mail was sent

  // Status: PENDING | ORDER_SENT | IN_TRANSIT | DELIVERED | COMPLETED
  status String  @default("PENDING")
  notes  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([isDeleted])
  @@index([refId])
  @@index([complaintTicket])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String // CREATE, UPDATE, DELETE, VIEW, STATUS_CHANGE, etc.
  entityType String // Shipment, Complaint, Repossession, Redeployment
  entityId   String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress  String?
  userAgent  String?
  changes    String? // JSON string for before/after values
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model ApprovalRequest {
  id          String    @id @default(cuid())
  entityType  String // Shipment
  entityId    String
  action      String // DELETE | COMPLETE
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reason      String?
  payload     String?
  requesterId String
  requester   User      @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  approverId  String?
  approver    User?     @relation("ApprovalApprover", fields: [approverId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?

  @@index([entityType, entityId])
  @@index([status])
  @@index([requesterId])
}

model CustomRole {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@index([name])
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  location    String?
  parentId    String?
  parent      Team?    @relation("TeamHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Team[]   @relation("TeamHierarchy")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members   User[]
  shipments Shipment[]

  @@index([name])
  @@index([code])
  @@index([location])
}

model PermissionRequest {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation("PermissionRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  requestedRole String
  currentRole   String
  reason        String
  status        String    @default("PENDING")
  reviewedBy    String?
  reviewer      User?     @relation("PermissionRequestReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt    DateTime?
  reviewNotes   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model TemporaryAccess {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("TemporaryAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   String
  granter     User      @relation("TemporaryAccessGranter", fields: [grantedBy], references: [id], onDelete: Cascade)
  role        String
  permissions Json?
  reason      String
  expiresAt   DateTime
  isRevoked   Boolean   @default(false)
  revokedAt   DateTime?
  revokedBy   String?
  revoker     User?     @relation("TemporaryAccessRevoker", fields: [revokedBy], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([isRevoked])
}

model Delegation {
  id          String   @id @default(cuid())
  fromUserId  String
  fromUser    User     @relation("DelegationFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUserId    String
  toUser      User     @relation("DelegationTo", fields: [toUserId], references: [id], onDelete: Cascade)
  permissions Json
  reason      String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([fromUserId])
  @@index([toUserId])
  @@index([isActive])
  @@index([endDate])
}

model ApprovalThreshold {
  id              String   @id @default(cuid())
  entityType      String
  action          String
  requiredRole    String
  requiresMFA     Boolean  @default(false)
  approvalCount   Int      @default(1)
  isAmountBased   Boolean  @default(false)
  thresholdAmount Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([entityType, action])
  @@index([entityType])
}

model MFARequirement {
  id          String   @id @default(cuid())
  action      String   @unique
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([action])
  @@index([isActive])
}
